<div class="page-wrapper">

  <div class="form-container">
    <h1 class="form-title">✏️ Edit Property</h1>

    <%= form_with model: @property do |f| %>

      <div class="form-grid">

        <div class="field">
          <%= f.label :name %>
          <%= f.text_field :name, class: "input" %>
        </div>

        <div class="field">
          <%= f.label :price %>
          <%= f.number_field :price, class: "input" %>
        </div>

        <div class="field">
          <%= f.label :property_type %>
          <%= f.select :property_type, ["Flat","Villa","Plot"], {}, class: "input" %>
        </div>

        <div class="field">
          <%= f.label :status %>
          <%= f.select :status, ["Available","Sold","Rented"], {}, class: "input" %>
        </div>

        <div class="field full">
          <%= f.label :location %>
          <%= f.text_field :location, class: "input" %>
        </div>

        <div class="field full">
          <%= f.label :address %>
          <%= f.text_field :address, class: "input" %>
        </div>

        <div class="field">
          <%= f.label :city %>
          <%= f.text_field :city, class: "input" %>
        </div>

        <div class="field">
          <%= f.label :state %>
          <%= f.text_field :state, class: "input" %>
        </div>

        <div class="field">
          <%= f.label :country %>
          <%= f.text_field :country, class: "input" %>
        </div>

        <div class="field">
          <%= f.label :pincode %>
          <%= f.text_field :pincode, class: "input" %>
        </div>

        <div class="field full">
          <%= f.label :description %>
          <%= f.text_area :description, class: "input textarea" %>
        </div>

        <div class="upload-box" id="dropArea">
        <p>📁 Drag & Drop Image Here</p>
        <p>or</p>

        <label class="upload-btn">
          Select Image
          <%= f.file_field :image, id: "fileInput", hidden: true %>
        </label>

        <img id="previewImage" style="display:none; width:150px; margin-top:10px;" />
      </div>
      <div class="upload-box" id="dropArea">
        <p>📁 Drag & Drop Image Here</p>
        <p>or</p>

        <label class="upload-btn">
          Select Image
          <%= f.file_field :image, id: "fileInput", hidden: true %>
        </label>

        <img id="previewImage" style="display:none; width:150px; margin-top:10px;" />
      </div>
      </div>

      <div class="form-footer">
        <%= f.submit "💾 Update Property", class: "btn-primary" %>
      </div>

    <% end %>
  </div>

</div>

<style>
  body {
  margin: 0;
  font-family: 'Inter', sans-serif;
  background: #f4f6fb;
}

/* Page center */
.page-wrapper {
  display: flex;
  justify-content: center;
  padding: 50px 20px;
}

/* Card */
.form-container {
  width: 100%;
  max-width: 900px;
  background: white;
  padding: 35px;
  border-radius: 16px;
  box-shadow: 0 15px 40px rgba(0,0,0,0.08);
}

.upload-box {
  border: 2px dashed #aaa;
  padding: 30px;
  text-align: center;
  border-radius: 10px;
  cursor: pointer;
}

.upload-box.dragover {
  border-color: green;
}

/* Title */
.form-title {
  text-align: center;
  margin-bottom: 25px;
  font-size: 24px;
}

/* Grid */
.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18px;
}

/* Field */
.field {
  display: flex;
  flex-direction: column;
}

.full {
  grid-column: span 2;
}

/* Label */
label {
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 6px;
}

/* Input */
.input {
  padding: 11px;
  border-radius: 8px;
  border: 1px solid #ddd;
  background: #fafafa;
  transition: 0.2s;
}

.input:focus {
  border-color: #6366f1;
  background: white;
  outline: none;
  box-shadow: 0 0 6px rgba(99,102,241,0.2);
}

/* Textarea */
.textarea {
  min-height: 90px;
  resize: none;
}

/* Footer */
.form-footer {
  margin-top: 25px;
}

/* Button */
.btn-primary {
  width: 100%;
  padding: 14px;
  border: none;
  border-radius: 10px;
  background: linear-gradient(45deg, #6366f1, #4f46e5);
  color: white;
  font-size: 16px;
  cursor: pointer;
  transition: 0.3s;
}

.btn-primary:hover {
  transform: translateY(-1px);
}

/* Responsive */
@media (max-width: 768px) {
  .form-grid {
    grid-template-columns: 1fr;
  }

  .full {
    grid-column: span 1;
  }
}
</style>

<script>
  document.addEventListener("turbo:load", function () {

  const dropArea = document.getElementById("dropArea");
  const fileInput = document.getElementById("fileInput");
  const preview = document.getElementById("previewImage");

  if (!dropArea) return;

  dropArea.addEventListener("click", () => fileInput.click());

  dropArea.addEventListener("dragover", (e) => {
    e.preventDefault();
    dropArea.classList.add("dragover");
  });

  dropArea.addEventListener("dragleave", () => {
    dropArea.classList.remove("dragover");
  });

  dropArea.addEventListener("drop", (e) => {
    e.preventDefault();
    dropArea.classList.remove("dragover");

    const file = e.dataTransfer.files[0];
    fileInput.files = e.dataTransfer.files;

    preview.src = URL.createObjectURL(file);
    preview.style.display = "block";
  });

  fileInput.addEventListener("change", () => {
    const file = fileInput.files[0];
    if (file) {
      preview.src = URL.createObjectURL(file);
      preview.style.display = "block";
    }
  });

});
</script>