<div class="page">
  <div class="form-container">
    <div class="form-card">

      <h2 class="title">🏠 Add Property</h2>

      <%= form_with model: @property,
          html: { multipart: true },
          class: "property-form" do |f| %>

        <!-- BASIC DETAILS -->
        <div class="section">
          <h4>Basic Details</h4>

          <div class="grid">
            <div class="field">
              <label>Name</label>
              <%= f.text_field :name,
                  class: "input",
                  placeholder: "Luxury Villa..." %>
            </div>

            <div class="field">
              <label>Price</label>
              <%= f.number_field :price,
                  class: "input",
                  placeholder: "5000000" %>
            </div>

            <div class="field">
              <label>Type</label>
              <%= f.select :property_type,
                  ["Flat", "Villa", "Plot"],
                  {},
                  class: "input" %>
            </div>

            <div class="field">
              <label>Status</label>
              <%= f.select :status,
                  ["Available", "Sold", "Rented"],
                  {},
                  class: "input" %>
            </div>
          </div>
        </div>

        <!-- LOCATION -->
        <div class="section">
          <h4>Location</h4>

          <div class="grid">

            <div class="field full">
              <label>Search Location</label>
              <%= f.text_field :location,
                  id: "location-input",
                  class: "input",
                  placeholder: "Location..." %>
            </div>

            <div class="field">
              <label>City</label>
              <%= f.text_field :city,
                  class: "input",
                  placeholder: "City..." %>
            </div>

            <div class="field">
              <label>State</label>
              <%= f.text_field :state,
                  class: "input",
                  placeholder: "State..." %>
            </div>

            <div class="field">
              <label>Country</label>
              <%= f.text_field :country,
                  class: "input",
                  placeholder: "Country..." %>
            </div>

            <div class="field">
              <label>Pincode</label>
              <%= f.text_field :pincode,
                  class: "input",
                  placeholder: "Pincode..." %>
            </div>
          </div>
        </div>

        <!-- CONTACT -->
        <div class="section">
          <h4>Contact</h4>

          <div class="field">
            <label>Phone</label>

            <%= f.telephone_field :phone_number,
                class: "input",
                placeholder: "Phone number..." %>
          </div>
        </div>

        <!-- DESCRIPTION -->
        <div class="section">
          <h4>Description</h4>

          <%= f.text_area :description,
              class: "input textarea",
              placeholder: "Description..." %>
        </div>

        <!-- IMAGE UPLOAD -->
        <div class="section">
          <h4>Upload Image</h4>

          <div class="upload-box" id="dropArea">

            <p id="uploadText">
              📁 Drag & Drop or Click to Upload
            </p>

            <%= f.file_field :image,
                id: "fileInput",
                accept: "image/*",
                hidden: true %>

            <img id="previewImage" alt="Preview Image" />

            <button
              type="button"
              id="removeImageBtn">
              ✖ Remove
            </button>

          </div>
        </div>

        <!-- SUBMIT -->
        <%= f.submit "🚀 Save Property",
            class: "submit-btn" %>

      <% end %>
    </div>
  </div>
</div>

<style>
/* PAGE */
.page{
  background: linear-gradient(135deg,#eef2ff,#ffffff);
  min-height: 100vh;
  padding: 40px 15px;
  font-family: Arial, sans-serif;
}

/* CONTAINER */
.form-container{
  max-width: 900px;
  margin: auto;
}

/* CARD */
.form-card{
  background: #ffffff;
  padding: 35px;
  border-radius: 18px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.08);
}

.title{
  margin-bottom: 30px;
  text-align: center;
  color: #4f46e5;
}

/* SECTION */
.section{
  margin-bottom: 30px;
}

.section h4{
  margin-bottom: 15px;
  color: #6366f1;
  font-size: 18px;
}

/* GRID */
.grid{
  display: grid;
  grid-template-columns: repeat(2,1fr);
  gap: 20px;
}

.full{
  grid-column: span 2;
}

/* FIELD */
.field{
  display: flex;
  flex-direction: column;
}

.field label{
  margin-bottom: 8px;
  font-weight: 600;
  color: #333;
}

/* INPUT */
.input{
  width: 100%;
  padding: 12px 14px;
  border-radius: 10px;
  border: 1px solid #d1d5db;
  background: #f9fafb;
  font-size: 15px;
  transition: 0.3s;
  box-sizing: border-box;
}

.input:focus{
  border-color: #6366f1;
  box-shadow: 0 0 8px rgba(99,102,241,0.25);
  outline: none;
  background: #fff;
}

/* TEXTAREA */
.textarea{
  height: 120px;
  resize: vertical;
}

/* UPLOAD BOX */
.upload-box{
  border: 2px dashed #cbd5e1;
  padding: 35px 20px;
  text-align: center;
  border-radius: 14px;
  cursor: pointer;
  transition: 0.3s;
  background: #f8fafc;
  position: relative;
}

.upload-box:hover{
  border-color: #6366f1;
  background: #eef2ff;
}

/* PREVIEW IMAGE */
#previewImage{
  width: 100%;
  max-height: 300px;
  object-fit: cover;
  margin-top: 15px;
  border-radius: 14px;
  display: none;
}

/* REMOVE BUTTON */
#removeImageBtn{
  margin-top: 15px;
  background: #ef4444;
  color: #fff;
  border: none;
  padding: 10px 16px;
  border-radius: 10px;
  cursor: pointer;
  display: none;
  transition: 0.3s;
}

#removeImageBtn:hover{
  background: #dc2626;
}

/* SUBMIT BUTTON */
.submit-btn{
  width: 100%;
  padding: 14px;
  background: linear-gradient(45deg,#6366f1,#4f46e5);
  color: #fff;
  border: none;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: 0.3s;
}

.submit-btn:hover{
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(79,70,229,0.3);
}

/* MOBILE */
@media (max-width: 768px){

  .grid{
    grid-template-columns: 1fr;
  }

  .full{
    grid-column: span 1;
  }

  .form-card{
    padding: 20px;
  }
}
</style>

<script>
document.addEventListener("turbo:load", () => {

  const dropArea = document.getElementById("dropArea");
  const fileInput = document.getElementById("fileInput");
  const previewImage = document.getElementById("previewImage");
  const removeBtn = document.getElementById("removeImageBtn");
  const uploadText = document.getElementById("uploadText");

  if (!dropArea || !fileInput) return;

  /* CLICK TO OPEN FILE */
  dropArea.addEventListener("click", (e) => {

    if (e.target.id !== "removeImageBtn") {
      fileInput.click();
    }

  });

  /* FILE CHANGE */
  fileInput.addEventListener("change", () => {

    const file = fileInput.files[0];

    if (file) {
      showPreview(file);
    }

  });

  /* DRAG OVER */
  dropArea.addEventListener("dragover", (e) => {

    e.preventDefault();
    dropArea.style.borderColor = "#6366f1";

  });

  /* DRAG LEAVE */
  dropArea.addEventListener("dragleave", () => {

    dropArea.style.borderColor = "#cbd5e1";

  });

  /* DROP FILE */
  dropArea.addEventListener("drop", (e) => {

    e.preventDefault();

    dropArea.style.borderColor = "#cbd5e1";

    const file = e.dataTransfer.files[0];

    if (file) {

      fileInput.files = e.dataTransfer.files;
      showPreview(file);

    }

  });

  /* REMOVE IMAGE */
  removeBtn.addEventListener("click", (e) => {

    e.stopPropagation();

    fileInput.value = "";
    previewImage.src = "";
    previewImage.style.display = "none";

    removeBtn.style.display = "none";
    uploadText.style.display = "block";

  });

  /* PREVIEW FUNCTION */
  function showPreview(file){

    if (!file.type.startsWith("image/")) {
      alert("Please upload an image file.");
      return;
    }

    previewImage.src = URL.createObjectURL(file);
    previewImage.style.display = "block";

    removeBtn.style.display = "inline-block";
    uploadText.style.display = "none";
  }

});
</script>