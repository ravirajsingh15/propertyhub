<div class="auth-container">

  <div class="auth-card">
    <h2>Login</h2>

    <% if alert %>
      <p class="error"><%= alert %></p>
    <% end %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="form-group">
        <%= f.label :name %>
        <%= f.text_field :name, autofocus: true, placeholder: "Enter your name", class: "input" %>
      </div>

      <div class="form-group">
      <%= f.label :phone_number %>
      <%= f.text_field :phone_number,
      autofocus: true,
      placeholder: "Enter your phone number",
      class: "input" %> 
      </div>

      <!-- Email -->
      <div class="form-group">
        <%= f.label :email %>
        <%= f.email_field :email, autofocus: true, placeholder: "Enter your email", class: "input" %>
      </div>

      <!-- Password with Eye -->
      <div class="form-group password-wrapper">
        <%= f.label :password %>

        <%= f.password_field :password,
              id: "login-password",
              placeholder: "Enter password",
              class: "input" %>

        <span class="toggle-password" onclick="toggleLoginPassword()">👁</span>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="remember">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me %>
        </div>
      <% end %> <br><br>

      <!-- Submit -->
      <div class="form-group">
        <%= f.submit "Login", class: "btn-login" %>
      </div>

    <% end %>

    <div class="links">
      <%= render "devise/shared/links" %>
    </div>

  </div>

</div>

<style>
body {
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
  background: linear-gradient(135deg, #6366f1, #4f46e5);
}

.auth-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.auth-card {
  background: white;
  padding: 35px;
  border-radius: 14px;
  width: 100%;
  max-width: 380px;
  box-shadow: 0 12px 30px rgba(0,0,0,0.2);
  text-align: center;
}

.form-group {
  margin-bottom: 15px;
  text-align: left;
  position: relative;
}

.input {
  width: 100%;
  padding: 10px;
  border-radius: 8px;
  border: 1px solid #ccc;
  margin-top: 5px;
}

.input:focus {
  border-color: #6366f1;
  outline: none;
  box-shadow: 0 0 6px rgba(99,102,241,0.3);
}

.toggle-password {
  position: absolute;
  right: 10px;
  top: 38px;
  cursor: pointer;
  font-size: 18px;
  color: #666;
}

.toggle-password:hover {
  color: #000;
}

.btn-login {
  width: 100%;
  padding: 12px;
  background: linear-gradient(45deg, #6366f1, #4f46e5);
  border: none;
  color: white;
  border-radius: 10px;
  font-weight: bold;
  cursor: pointer;
}

.btn-login:hover {
  transform: translateY(-2px);
}

.remember {
  display: flex;
  align-items: center;
  font-size: 13px;
}

.error {
  color: red;
  margin-bottom: 10px;
}

.links {
  margin-top: 15px;
  font-size: 14px;
}
</style>

<script>
function toggleLoginPassword() {
  const field = document.getElementById("login-password");
  field.type = field.type === "password" ? "text" : "password";
}
</script>