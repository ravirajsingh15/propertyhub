<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
</head>

<body style="margin:0; padding:0; font-family: Arial, sans-serif; background:#f4f6f8;">

  <div style="max-width:600px; margin:30px auto; background:white; border-radius:10px; overflow:hidden; box-shadow:0 4px 10px rgba(0,0,0,0.1);">

    <!-- Header -->
    <div style="background:#2ecc71; padding:20px; text-align:center; color:white;">
      <h2 style="margin:0;">🏡 New Property Added</h2>
    </div>

    <!-- Image -->
    <img src="https://images.unsplash.com/photo-1568605114967-8130f3a36994"
         alt="Property Image"
         style="width:100%; height:200px; object-fit:cover;">

    <!-- Content -->
    <div style="padding:20px;">

      <p style="font-size:16px; color:#333;">A new property has been added to your system:</p>

      <div style="background:#f9f9f9; padding:15px; border-radius:8px; margin-top:10px;">

        <p><strong>🏷 Name:</strong> <%= @property.name %></p>
        <p><strong>📍 Location:</strong> <%= @property.location %></p>
        <p><strong>💰 Price:</strong> ₹ <%= @property.price %></p>

        <% if @property.description.present? %>
          <p><strong>📝 Description:</strong> <%= @property.description %></p>
        <% end %>

      </div>

      <!-- Button -->
      <div style="text-align:center; margin-top:20px;">
        <a href="http://localhost:3000/properties/<%= @property.id %>"
           style="background:#2ecc71; color:white; padding:10px 20px; text-decoration:none; border-radius:5px;">
          View Property
        </a>
      </div>

    </div>

    <!-- Footer -->
    <div style="background:#f1f1f1; padding:10px; text-align:center; font-size:12px; color:#777;">
      © <%= Time.current.year %> Property Hub
    </div>

  </div>

</body>
</html>