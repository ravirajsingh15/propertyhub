<!DOCTYPE html>
<html>
  <head>
    <title>PropertyHub</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application" %>
    <%= javascript_importmap_tags %>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  </head>

  <body>

  <% if user_signed_in? %>

    <!-- ✅ NAVBAR -->
    <div class="navbar">

      <div class="logo" id="logocss" onclick="logoClick()">🏠 Property Hub</div>

      <div class="location-filter">
        <span class="label">
          <i class="fa-solid fa-location-dot"></i> Location
        </span>

        <%= form_with url: properties_path, method: :get, local: true do %>

          <% params.except(:city, :controller, :action).each do |key, value| %>
            <%= hidden_field_tag key, value %>
          <% end %>

          <%= select_tag :city,
            options_for_select(
              [['All', 'all']] + Property.distinct.pluck(:city).compact.sort,
              params[:city]
            ),
            class: "city-dropdown",
            onchange: "this.form.submit();" %>

        <% end %>
      </div>

      <div class="profile-section">
        <span class="profile-btn" onclick="openProfile()">
          👤 <%= current_user.name.presence || "User" %>
        </span>
      </div>

    </div>

  <% end %>

  <!-- PAGE CONTENT -->
  <%= yield %>

  <% if user_signed_in? %>

    <!-- ✅ PROFILE MODAL -->
    <div id="profileModal" class="modal">
      <div class="modal-content">
        <span class="close-btn" onclick="closeProfile()">×</span>

        <h3>👤 Profile</h3>

        <p><strong>Name:</strong> <%= current_user.name || "Not set" %></p>
        <p><strong>Email:</strong> <%= current_user.email %></p>
        <p><strong>Phone:</strong> <%= current_user.phone_number %></p>

        <%= button_to "Logout",
              destroy_user_session_path,
              method: :delete,
              class: "logout-btn" %>

      </div>
    </div>

  <% end %>

  </body>
</html>


<style>
  .close-btn{
  position: relative;

  width: 42px;
  height: 42px;

  margin-left: auto;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 22px;
  font-weight: 700;

  color: #ffffff;

  background: linear-gradient(135deg, #ff4d4d, #e11d48);

  border: 2px solid rgba(255,255,255,0.2);
  border-radius: 50%;

  cursor: pointer;

  overflow: hidden;

  transition: all 0.35s ease;

  box-shadow:
    0 6px 18px rgba(225,29,72,0.35),
    inset 0 1px 2px rgba(255,255,255,0.25);
}

/* Shine Effect */
.close-btn::before{
  content: "";

  position: absolute;
  top: -100%;
  left: -100%;

  width: 200%;
  height: 200%;

  background: linear-gradient(
    120deg,
    transparent,
    rgba(255,255,255,0.35),
    transparent
  );

  transform: rotate(25deg);

  transition: 0.6s;
}

/* Hover */
.close-btn:hover{
  transform: rotate(90deg) scale(1.12);

  background: linear-gradient(135deg, #dc2626, #be123c);

  box-shadow:
    0 12px 28px rgba(220,38,38,0.45),
    0 0 18px rgba(255,77,77,0.5);
}

.close-btn:hover::before{
  top: 100%;
  left: 100%;
}

/* Click */
.close-btn:active{
  transform: scale(0.9);
}

/* Optional Glow Animation */
@keyframes pulseGlow{
  0%{
    box-shadow:
      0 6px 18px rgba(225,29,72,0.35);
  }

  50%{
    box-shadow:
      0 10px 26px rgba(255,77,77,0.55);
  }

  100%{
    box-shadow:
      0 6px 18px rgba(225,29,72,0.35);
  }
}

.close-btn{
  animation: pulseGlow 2s infinite;
}

  .navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(45deg, #2c3e50, #34495e);
  padding: 12px 20px;
  color: white;
  border-radius: 10px;
  margin-bottom: 15px;
}

.logo {
  font-size: 20px;
  font-weight: bold;
  cursor: pointer;
}

.logout-btn{
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: #ffffff;
  border: none;
  padding: 10px 18px;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25);
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

/* Hover */
.logout-btn:hover{
  transform: translateY(-2px);
  background: linear-gradient(135deg, #dc2626, #b91c1c);
  box-shadow: 0 8px 20px rgba(220, 38, 38, 0.35);
}

/* Click */
.logout-btn:active{
  transform: scale(0.96);
}

/* Focus */
.logout-btn:focus{
  outline: none;
  box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.2);
}

.location-filter {
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(255,255,255,0.1);
  padding: 6px 12px;
  border-radius: 8px;
}

.label {
  font-size: 14px;
  display: flex;
  align-items: center;
  gap: 5px;
}

.city-dropdown {
  border: none;
  padding: 6px 10px;
  border-radius: 6px;
  background: white;
  cursor: pointer;
}

.profile-btn {
  background: white;
  color: #2c3e50;
  padding: 6px 14px;
  border-radius: 20px;
  cursor: pointer;
  font-weight: bold;
}

/* MODAL */
.modal {
  display: none;
  position: fixed;
  inset: 0;
  cursor: pointer;
  background: rgba(0,0,0,0.5);
  justify-content: center;
  align-items: center;
}

.modal-content {
  background: white;
  padding: 20px;
  border-radius: 10px;
}
</style>

<script>
  function logoClick() {
    window.location.href = "http://127.0.0.1:3000/";
  }

function openProfile() {
  document.getElementById("profileModal").style.display = "flex";
}

function closeProfile() {
  document.getElementById("profileModal").style.display = "none";
}

window.onclick = function(e) {
  const modal = document.getElementById("profileModal");
  if (e.target === modal) {
    modal.style.display = "none";
  }
}
</script>